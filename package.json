{
  "name": "memchat",
  "version": "1.0.0",
  "description": "Production-Ready Multi-Tenant AI Memory System - A secure, scalable backend for building AI applications with persistent memory",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "mcp": "tsx src/mcp/index.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "exports": {
    ".": "./dist/server.js",
    "./sdk": "./dist/sdk/index.js"
  },
  "keywords": [
    "ai",
    "memory",
    "multi-tenant",
    "rag",
    "vector-database",
    "milvus",
    "openai",
    "chatgpt",
    "llm",
    "embeddings",
    "typescript",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/memchat.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/memchat/issues"
  },
  "homepage": "https://github.com/your-username/memchat#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "@zilliz/milvus2-sdk-node": "^2.4.9",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.10.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.67.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/handlebars": "^4.0.40",
    "@types/ioredis": "^4.28.10",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
