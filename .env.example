# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (IMPORTANT: Change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Milvus Configuration (defaults work for local Docker)
MILVUS_ADDRESS=localhost:19530
MILVUS_TOKEN=root:Milvus

# LLM Configuration (OpenAI-compatible API)
# Choose one of the following configurations:

# --- Option 1: OpenAI ---
# LLM_API_KEY=sk-your-openai-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4

# --- Option 2: Azure OpenAI ---
# LLM_API_KEY=your-azure-key
# LLM_BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# LLM_MODEL=gpt-4

# --- Option 3: ByteDance Ark ---
# LLM_API_KEY=your-ark-api-key
# LLM_BASE_URL=https://ark-cn-beijing.bytedance.net/api/v3
# LLM_MODEL=your-endpoint-id

# --- Option 4: Local LLM (Ollama/LMStudio) ---
# LLM_API_KEY=not-needed
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# --- Option 5: Other OpenAI-compatible APIs ---
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Embedding Model (for memory vectorization)
LLM_EMBEDDING_MODEL=text-embedding-ada-002

# Chunking Configuration
CHUNK_MAX_TOKENS=400
CHUNK_OVERLAP_TOKENS=80
