# ============ Server Configuration ============
PORT=3000
NODE_ENV=development

# ============ JWT ============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============ Redis (optional, for persistent Working Memory) ============
# REDIS_URL=redis://localhost:6379

# ============ Milvus Configuration ============
MILVUS_ADDRESS=localhost:19530
MILVUS_TOKEN=root:Milvus

# ============ Vector Store ============
# VECTOR_STORE_TYPE=milvus    # milvus (default)

# ============ LLM Configuration (OpenAI-compatible API) ============
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Embedding Model
LLM_EMBEDDING_MODEL=text-embedding-ada-002

# ============ Chunking Configuration ============
CHUNK_MAX_TOKENS=400
CHUNK_OVERLAP_TOKENS=80

# ============ Memory Management ============
# MAX_MEMORIES_PER_USER=1000
# MEMORY_CLEANUP_THRESHOLD=0.9
# MEMORY_CLEANUP_TARGET=0.7
# MEMORY_CLEANUP_BATCH=50
# MEMORY_SIMILARITY_TOP_K=8
# MEMORY_SIMILARITY_THRESHOLD=0.7

# ============ Memory Compression ============
# MEMORY_COMPRESSION_ENABLED=true
# MEMORY_COMPRESSION_TRIGGER_RATIO=0.5
# MEMORY_CLUSTER_THRESHOLD=0.5
# MEMORY_CLUSTER_MIN_SIZE=3
# MEMORY_COMPRESSION_HOUR=3

# ============ Working Memory ============
# WORKING_MEMORY_ENABLED=true
# WORKING_MEMORY_MAX_MESSAGES=20
# WORKING_MEMORY_TTL_MINUTES=120

# ============ Embedding Cache ============
# EMBEDDING_CACHE_ENABLED=true
# EMBEDDING_CACHE_MAX_SIZE=2000

# ============ Hybrid Retrieval Weights ============
# RETRIEVAL_VECTOR_WEIGHT=0.50
# RETRIEVAL_KEYWORD_WEIGHT=0.20
# RETRIEVAL_TIME_DECAY_WEIGHT=0.15
# RETRIEVAL_IMPORTANCE_WEIGHT=0.15
# RETRIEVAL_HALF_LIFE_DAYS=90
# RETRIEVAL_CANDIDATE_MULTIPLIER=3

# ============ Quota Management ============
# QUOTA_ENABLED=false
# QUOTA_DEFAULT_MAX_MEMORIES=1000
# QUOTA_REQUESTS_PER_MINUTE=60
# QUOTA_DB_PATH=./data/quota.db

# ============ Memory Graph (Knowledge Graph) ============
# MEMORY_GRAPH_ENABLED=true
# MEMORY_GRAPH_DB_PATH=./data/memory-graph.db

# ============ Emotion Tracking ============
# EMOTION_TRACKING_ENABLED=true
# EMOTION_DB_PATH=./data/emotion.db

# ============ Persona Evolution ============
# PERSONA_EVOLUTION_ENABLED=true
# PERSONA_REFLECT_EVERY_N=10
# PERSONA_EVOLUTION_DB_PATH=./data/persona-evolution.db

# ============ MCP Server ============
# MCP_ENABLED=false
# MCP_PORT=3001

# ============ Multimodal ============
# MULTIMODAL_ENABLED=false
# MULTIMODAL_MAX_FILE_SIZE_MB=10
